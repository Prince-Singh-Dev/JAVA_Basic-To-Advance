class myThrz extends Thread{
    public myThrz(String name){
        super(name);
    }
    public void run(){
        for (int j = 0; j<5 ; j++){
            System.out.println("Thank You " + this.getName());
        }
    }
}

public class Thread_Priorities {
    public static void main(String[] args) {
        myThrz t1 = new myThrz("Prince (Most Important)");
        myThrz t2 = new myThrz("Harry");
        myThrz t3 = new myThrz("Ram ");
        myThrz t4 = new myThrz("Candre");
        myThrz t5 = new myThrz("Hensie");
        t1.setPriority(Thread.MAX_PRIORITY);
        t1.start();
        t2.start();
        t3.start();
        t4.start();
        t5.start();
    }
}

