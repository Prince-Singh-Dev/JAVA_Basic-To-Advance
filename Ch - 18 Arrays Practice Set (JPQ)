5. Write a JAVA program to reverse an array

public class Arrays {
    public static void main(String[] args){
        int [] arr = {10,20,30,40,60};
        System.out.println("Reversed array : ");
        for(int i=(arr.length-1); i>=0 ; i--){
            System.out.println(arr[i]);
        }
    }
}
